		<IState type="e">
			<_id type="a">GUID 3790ff7c-3d16-4c8c-9d85-14b49c8563cf</_id>
			<_name type="a">Aktywny</_name>
			<_modifiedTimeWeak type="a">6.21.2026::14:59:37</_modifiedTimeWeak>
			<_modifiedTime type="a">6.21.2026::14:59:37</_modifiedTime>
			<_parent type="s">GUID 3280588f-f92e-4c40-9f53-31c262e19235</_parent>
			<_defaultTrans type="s"></_defaultTrans>
			<_entryAction type="p"><IAction type="e">
				<_id type="a">GUID a0740d6d-efc1-41a6-9926-a55b1ec04681</_id>
				<_myState type="a">4096</_myState>
				<_modifiedTimeWeak type="a">6.21.2026::14:59:37</_modifiedTimeWeak>
				<_modifiedTime type="a">6.21.2026::14:59:37</_modifiedTime>
				<_body type="a">std::cout &lt;&lt; &quot;\n=== [STEROWNIK sEMG] ===&quot; &lt;&lt; std::endl;%0D
std::cout &lt;&lt; &quot;[INIT] Przej%9Ccie w tryb AKTYWNY.&quot; &lt;&lt; std::endl;%0D
std::cout &lt;&lt; &quot;[HARDWARE] Konfiguracja przetwornika ADC na g%B3%F3wnym interfejsie (RPi 5)...&quot; &lt;&lt; std::endl;%0D
std::cout &lt;&lt; &quot;[MEM] Alokacja bufor%F3w pami%EAci dla okna czasowego sygna%B3u.&quot; &lt;&lt; std::endl;%0D
%0D
// Resetowanie aktualnego gestu zabezpieczaj%B9ce przed b%B3%EAdami pami%EAci%0D
this-&gt;aktualnyGest = BRAK; %0D
%0D
std::cout &lt;&lt; &quot;[SYS] Bufory wyczyszczone. Nas%B3uchiwanie na aktywno%9C%E6 elektrod...&quot; &lt;&lt; std::endl;</_body>
			</IAction>
			</_entryAction>
		</IState>
		<IState type="e">
			<_id type="a">GUID 4b468d30-6afb-4f96-bd04-923d43543477</_id>
			<_name type="a">Kalibracja</_name>
			<_modifiedTimeWeak type="a">6.21.2026::15:12:22</_modifiedTimeWeak>
			<_modifiedTime type="a">6.21.2026::15:12:22</_modifiedTime>
			<_parent type="s">GUID 3280588f-f92e-4c40-9f53-31c262e19235</_parent>
			<_defaultTrans type="s"></_defaultTrans>
			<_entryAction type="p"><IAction type="e">
				<_id type="a">GUID 86177a65-896f-4ce7-a047-1c1b174daf2e</_id>
				<_myState type="a">4096</_myState>
				<_modifiedTimeWeak type="a">1.2.1990::0:0:0</_modifiedTimeWeak>
				<_modifiedTime type="a">1.2.1990::0:0:0</_modifiedTime>
				<_body type="a">std::cout &lt;&lt; &quot;\n=== [MODUL KALIBRACJI sEMG] ===&quot; &lt;&lt; std::endl;%0D
std::cout &lt;&lt; &quot;[CALIB] Rozpoczecie procedury profilowania elektrod.&quot; &lt;&lt; std::endl;%0D
%0D
// Symulacja pomiaru szumu bazowego (spoczynkowego)%0D
std::cout &lt;&lt; &quot;[CALIB] Faza 1: Akwizycja szumu spoczynkowego (Relaxation Phase)...&quot; &lt;&lt; std::endl;%0D
int baselineNoise = (rand() %25 40) + 15;%0D
std::cout &lt;&lt; &quot;[CALIB] Wyznaczony poziom szumu: &quot; &lt;&lt; baselineNoise &lt;&lt; &quot; uV.&quot; &lt;&lt; std::endl;%0D
%0D
// Symulacja pomiaru maksymalnego skurczu (MVC)%0D
std::cout &lt;&lt; &quot;[CALIB] Faza 2: Akwizycja maksymalnego skurczu (MVC Phase)...&quot; &lt;&lt; std::endl;%0D
int maxContraction = (rand() %25 400) + 600;%0D
std::cout &lt;&lt; &quot;[CALIB] Wyznaczone MVC: &quot; &lt;&lt; maxContraction &lt;&lt; &quot; uV.&quot; &lt;&lt; std::endl;%0D
%0D
std::cout &lt;&lt; &quot;[CALIB] Adaptacja wag i progow decyzyjnych algorytmu na podstawie MVC.&quot; &lt;&lt; std::endl;%0D
std::cout &lt;&lt; &quot;[CALIB] Kalibracja zakonczona. Wyzwalanie powrotu do trybu sterowania.&quot; &lt;&lt; std::endl;</_body>
			</IAction>
			</_entryAction>
			<_exitAction type="p"><IAction type="e">
				<_id type="a">GUID 3773de18-6930-4224-82a5-f60d696523cb</_id>
				<_modifiedTimeWeak type="a">6.21.2026::15:12:22</_modifiedTimeWeak>
				<_modifiedTime type="a">6.21.2026::15:12:22</_modifiedTime>
				<_body type="a">std::cout &lt;&lt; &quot;[CALIB] Kalibracja zakonczona. Wyzwalanie powrotu do trybu sterowania.&quot; &lt;&lt; std::endl;</_body>
			</IAction>
			</_exitAction>
		</IState>
