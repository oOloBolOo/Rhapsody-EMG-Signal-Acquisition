		<IState type="e">
			<_id type="a">GUID 9a2a8000-517d-4718-b6c1-c9aca6863346</_id>
			<_name type="a">AnalizaFFT</_name>
			<_modifiedTimeWeak type="a">6.21.2026::15:7:55</_modifiedTimeWeak>
			<_modifiedTime type="a">6.21.2026::15:7:55</_modifiedTime>
			<_parent type="s">GUID 4dc4c26d-7df6-46b8-8540-acdc9bcf906d</_parent>
			<_defaultTrans type="s"></_defaultTrans>
			<_entryAction type="p"><IAction type="e">
				<_id type="a">GUID e80171ba-c4e5-4393-a97c-698bfdfca5db</_id>
				<_myState type="a">4096</_myState>
				<_modifiedTimeWeak type="a">1.2.1990::0:0:0</_modifiedTimeWeak>
				<_modifiedTime type="a">1.2.1990::0:0:0</_modifiedTime>
				<_body type="a">std::cout &lt;&lt; &quot;\n=== [MODUL KLASYFIKATORA ML] ===&quot; &lt;&lt; std::endl;%0D
std::cout &lt;&lt; &quot;[FFT] Odebrano paczke danych. Obliczanie transformaty Fouriera...&quot; &lt;&lt; std::endl;%0D
%0D
// Symulacja ekstrakcji cech widmowych (np. dominujaca czestotliwosc w Hz)%0D
int dominujacaCzestotliwosc = (rand() %25 150) + 20; %0D
std::cout &lt;&lt; &quot;[FFT] Wyodrebniono cechy. Dominujace pasmo: &quot; &lt;&lt; dominujacaCzestotliwosc &lt;&lt; &quot; Hz.&quot; &lt;&lt; std::endl;%0D
%0D
std::cout &lt;&lt; &quot;[ML] Ladowanie wektora cech do modelu klasyfikatora...&quot; &lt;&lt; std::endl;%0D
%0D
// Prosta symulacja dzialania algorytmu wnioskujacego (3 rozne gesty)%0D
int wynikKlasyfikacji = rand() %25 3;%0D
%0D
std::cout &lt;&lt; &quot;[ML] Decyzja modelu: &quot;;%0D
switch(wynikKlasyfikacji) {%0D
    case 0:%0D
        std::cout &lt;&lt; &quot;CHWYT CYLINDRYCZNY (Power Grip)&quot; &lt;&lt; std::endl;%0D
        break;%0D
    case 1:%0D
        std::cout &lt;&lt; &quot;CHWYT PESETOWY (Pinch Grip)&quot; &lt;&lt; std::endl;%0D
        break;%0D
    case 2:%0D
        std::cout &lt;&lt; &quot;OTWARCIE DLONI (Hand Open)&quot; &lt;&lt; std::endl;%0D
        break;%0D
}%0D
%0D
std::cout &lt;&lt; &quot;[ML] Generowanie ramki sterujacej dla silnikow protezy.&quot; &lt;&lt; std::endl;</_body>
			</IAction>
			</_entryAction>
